{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "fitness-web/dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/route"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/route?path=:path*"
    }
  ]
}
